# RTC 配置
NEXT_PUBLIC_RTC_APP_ID=your_app_id_here
NEXT_PUBLIC_RTC_TOKEN=your_token_here
NEXT_PUBLIC_RTC_ROOM_ID=demo_room
NEXT_PUBLIC_RTC_USER_ID=user_123

# 火山引擎 OpenAPI 配置（用于 StartVoiceChat）
VOLCANO_ACCESS_KEY_ID=your_access_key_id_here
VOLCANO_SECRET_ACCESS_KEY=your_secret_access_key_here

# 火山引擎语音识别（ASR）配置
VOLCANO_ASR_APP_ID=your_asr_app_id_here
VOLCANO_ASR_ACCESS_TOKEN=your_asr_access_token_here

# 火山引擎语音合成（TTS）配置
VOLCANO_TTS_APP_ID=your_tts_app_id_here
VOLCANO_TTS_CLUSTER=volcano_tts

# 豆包 AI 配置
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_ENDPOINT_ID=your_doubao_endpoint_id_here
DOUBAO_MODEL=doubao-lite-4k

# 日志级别
LOG_LEVEL=info

# 开发环境配置
NODE_ENV=development
